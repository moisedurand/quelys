---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title       = 'Quélys — Cuisine Bistronomique à Nantes',
  description = 'Restaurant bistronomique au cœur du boulevard de la Prairie au Duc à Nantes. Cuisine de marché, produits locaux, cave raisonnée.',
  ogImage     = '/images/og-quelys.jpg',
  canonical   = Astro.url.href,
} = Astro.props;
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonical} />
  <meta property="og:locale"      content="fr_FR" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/logo-quelys.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;500;600&family=Inter:wght@300;400;500&family=Raleway:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />

  <!-- Iconify -->
  <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js" defer></script>
</head>

<body class="bg-surface text-cobalt overflow-x-hidden antialiased font-body">

  <!-- ══════════════════════════════════════════════
       NAVIGATION
  ══════════════════════════════════════════════ -->
  <nav class="nav-glass fixed top-0 w-full z-50 transition-all duration-300">
    <div class="max-w-[90rem] mx-auto px-8 h-24 flex items-center justify-between">

      <!-- Logo -->
      <a href="/" class="flex items-center h-full py-1 shrink-0">
        <img
          src="/images/logo-quelys.png"
          alt="Quélys — Cuisine bistronomique"
          class="h-16 md:h-20 w-auto max-w-none shrink-0 object-contain"
        />
      </a>

      <!-- Liens centre -->
      <div class="hidden md:flex items-center gap-8">
        {[
          { href: '/',             label: 'Accueil'      },
          { href: '/a-propos',     label: 'À Propos'     },
          { href: '/la-carte',     label: 'La Carte'     },
          { href: '/evenements',   label: 'Événements'   },
          { href: '/blog',         label: 'Actualités'   },
          { href: '/contact',      label: 'Contact'      },
        ].map(({ href, label }) => (
          <a
            href={href}
            class="text-white/80 hover:text-white text-xs uppercase tracking-[3px] transition-colors duration-300 font-sans"
          >
            {label}
          </a>
        ))}
      </div>

      <!-- Droite : CTA -->
      <div class="flex items-center gap-6">
        <a href="/contact" class="btn-primary hidden md:inline-flex" aria-label="Réserver une table" title="Réserver une table">
          <iconify-icon icon="solar:bookmark-linear" width="20" class="lg:hidden"></iconify-icon>
          <span class="hidden lg:inline">Réserver une table</span>
        </a>
        <!-- Burger mobile -->
        <button
          id="menu-btn"
          class="md:hidden text-white p-2"
          aria-label="Menu"
        >
          <iconify-icon icon="solar:hamburger-menu-linear" width="26"></iconify-icon>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden bg-cobalt/95 backdrop-blur-xl px-8 pb-8 flex flex-col gap-5 border-t border-white/10"
    >
      {[
        { href: '/',           label: 'Accueil'    },
        { href: '/a-propos',   label: 'À Propos'   },
        { href: '/la-carte',   label: 'La Carte'   },
        { href: '/evenements', label: 'Événements' },
        { href: '/blog',       label: 'Actualités' },
        { href: '/contact',    label: 'Contact'    },
      ].map(({ href, label }) => (
        <a href={href} class="text-white/80 hover:text-white text-sm uppercase tracking-widest pt-4 font-sans">
          {label}
        </a>
      ))}
      <a href="/contact" class="btn-primary mt-2 w-fit">Réserver une table</a>
    </div>
  </nav>

  <!-- ══════════════════════════════════════════════
       SLOT CONTENU
  ══════════════════════════════════════════════ -->
  <main>
    <slot />
  </main>

  <!-- ══════════════════════════════════════════════
       FOOTER
  ══════════════════════════════════════════════ -->
  <footer class="bg-cobalt noise-overlay pt-24 pb-8 relative">
    <div class="max-w-[80rem] mx-auto px-8 relative z-10">

      <div class="grid grid-cols-1 md:grid-cols-3 gap-16 mb-16">

        <!-- Brand -->
        <div class="flex flex-col items-start">
          <img
            src="/images/logo-quelys.png"
            alt="Quélys"
            class="h-16 w-auto mb-4"
            width="200"
            height="64"
          />
          <p class="text-white/60 text-sm font-light mb-5 leading-relaxed">
            28 boulevard de la Prairie au Duc,<br />44200 Nantes
          </p>
          <div class="w-10 h-px bg-apricot my-4"></div>
          <div class="flex items-center gap-4">
            <a href="https://facebook.com" target="_blank" rel="noopener" class="text-white hover:text-apricot transition-colors" aria-label="Facebook">
              <iconify-icon icon="solar:facebook-linear" width="20"></iconify-icon>
            </a>
            <a href="https://instagram.com/quelys.nantes" target="_blank" rel="noopener" class="text-white hover:text-apricot transition-colors" aria-label="Instagram">
              <iconify-icon icon="solar:camera-linear" width="20"></iconify-icon>
            </a>
          </div>
        </div>

        <!-- Plan du site -->
        <div class="flex flex-col items-start">
          <span class="text-white/60 text-xs uppercase tracking-[4px] mb-6 font-semibold font-sans">Plan du site</span>
          <ul class="flex flex-col gap-3">
            {[
              { href: '/',             label: 'Accueil'       },
              { href: '/a-propos',     label: 'À propos'      },
              { href: '/la-carte',     label: 'La Carte'      },
              { href: '/evenements',   label: 'Événements'    },
              { href: '/blog',         label: 'Actualités'    },
              { href: '/contact',      label: 'Contact & Accès'},
            ].map(({ href, label }) => (
              <li>
                <a href={href} class="text-white/80 hover:text-white text-sm font-light transition-colors">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Horaires & contact -->
        <div class="flex flex-col items-start">
          <span class="text-white/60 text-xs uppercase tracking-[4px] mb-6 font-semibold font-sans">Nous trouver</span>
          <div class="flex flex-col gap-3 mb-8 text-white/80 text-sm font-light">
            <span class="flex items-center gap-3">
              <iconify-icon icon="solar:phone-linear" width="18" class="text-white/50"></iconify-icon>
              <a href="tel:+33688672921" class="hover:text-white transition-colors">06 88 67 29 21</a>
            </span>
            <span class="flex items-center gap-3">
              <iconify-icon icon="solar:letter-linear" width="18" class="text-white/50"></iconify-icon>
              <a href="mailto:contact@quelys-nantes.fr" class="hover:text-white transition-colors">contact@quelys-nantes.fr</a>
            </span>
            <span class="flex items-start gap-3 mt-2">
              <iconify-icon icon="solar:clock-circle-linear" width="18" class="text-white/50 mt-1 shrink-0"></iconify-icon>
              <span>
                Mar–Sam : 12h–14h30 · 19h–22h30
                <span class="text-white/50 text-xs mt-1 block">Fermé dimanche et lundi</span>
              </span>
            </span>
          </div>
          <!-- Réservation — remplacer href par URL Zenchef/TheFork -->
          <a href="https://www.zenchef.com/quelys-nantes" target="_blank" rel="noopener" class="btn-primary">
            Réserver une table
          </a>
        </div>

      </div>

      <!-- Bottom bar -->
      <div class="border-t border-muted/20 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
        <span class="text-muted text-xs font-light font-sans">© {new Date().getFullYear()} Quélys · Tous droits réservés</span>
        <div class="flex items-center gap-4 text-xs font-light text-muted/70 font-sans">
          <a href="/mentions-legales" class="hover:text-white transition-colors">Mentions légales</a>
          <span>·</span>
          <a href="/mentions-legales#confidentialite" class="hover:text-white transition-colors">Politique de confidentialité</a>
        </div>
      </div>

    </div>
  </footer>

  <!-- Mobile menu toggle -->
  <script>
    const btn  = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  </script>

</body>
</html>
