---
import Base from '../layouts/Base.astro';
---

<Base
  title="Quélys — Cuisine Bistronomique à Nantes"
  description="Restaurant bistronomique au 28 boulevard de la Prairie au Duc, Nantes. Cuisine de marché, chef Anthony Lusson, cave raisonnée. Réservation en ligne."
>

  <!-- ══════════════════════════════════════════
       1. HERO — Mosaïque 3 colonnes
  ══════════════════════════════════════════ -->
  <header class="relative h-screen w-full overflow-hidden bg-cobalt">

    <!-- Mosaïque photos -->
    <div class="absolute inset-0 w-full h-full flex">
      <!-- Gauche : salle -->
      <div class="w-[34%] h-full">
        <img
          src="/images/hero-salle.webp"
          alt="Salle du restaurant Quélys"
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>
      <!-- Centre : plat (décalé vers le haut) -->
      <div class="w-[34%] absolute left-[33%] z-10 shadow-[0_0_3rem_rgba(0,0,0,0.5)]"
           style="height: calc(100% + 3.75rem); top: -1.875rem;">
        <img
          src="/images/hero-plat.webp"
          alt="Plat dressé par le chef"
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>
      <!-- Droite : ambiance -->
      <div class="w-[34%] h-full absolute right-0 top-0">
        <img
          src="/images/hero-ambiance.webp"
          alt="Ambiance conviviale au restaurant"
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>
    </div>

    <!-- Dégradé cobalt (vertical) -->
    <div class="absolute inset-0 z-20 bg-gradient-to-b from-cobalt/80 via-cobalt/40 to-transparent"></div>
    <!-- Dégradé cobalt (horizontal, pour lisibilité du texte gauche) -->
    <div class="absolute inset-0 z-20 bg-gradient-to-r from-cobalt/85 via-cobalt/30 to-transparent md:via-cobalt/20"></div>

    <!-- Texte hero -->
    <div class="absolute z-30 top-1/2 -translate-y-[45%] left-[5vw] md:left-20 flex flex-col items-start w-full max-w-xl">

      <span class="label-tag mb-6 animate-fade-up-1">
        Nantes · Cuisine Bistronomique
      </span>

      <h1
        class="text-white text-[4rem] md:text-[5.5rem] leading-[0.92] tracking-tight font-normal flex flex-col font-script animate-fade-up-2"
        style="text-shadow: 0 2px 24px rgba(10,20,50,0.6)"
      >
        <span>L'essentiel</span>
        <span>du goût,</span>
        <span>de l'âme.</span>
      </h1>

      <p class="text-white text-base md:text-lg mt-8 max-w-md leading-relaxed font-normal animate-fade-up-3" style="text-shadow: 0 1px 12px rgba(10,20,50,0.55)">
        Une cuisine de marché exigeante et conviviale, au cœur du boulevard de la Prairie au Duc.
      </p>

      <div class="flex flex-wrap items-center gap-4 mt-10 animate-fade-up-4">
        <!-- Remplacer href par URL Zenchef/TheFork -->
        <a href="https://www.zenchef.com/quelys-nantes" target="_blank" rel="noopener" class="btn-primary">
          Réserver une table
        </a>
        <a href="/la-carte" class="btn-ghost">
          Découvrir la carte
        </a>
      </div>
    </div>

    <!-- Watermark QL -->
    <div class="absolute bottom-[-2rem] right-[-1rem] z-30 opacity-10 pointer-events-none text-white text-[11rem] leading-none tracking-tighter font-sans select-none">
      QL
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-30 flex flex-col items-center gap-2">
      <div class="w-px h-10 bg-white/30 overflow-hidden relative">
        <div class="absolute top-0 left-0 w-full h-1/2 bg-white animate-scroll-pulse"></div>
      </div>
    </div>
  </header>


  <!-- ══════════════════════════════════════════
       2. BANDE CRÉDIBILITÉ
  ══════════════════════════════════════════ -->
  <section class="w-full bg-cobalt noise-overlay py-10 relative overflow-hidden">
    <div class="max-w-[90rem] mx-auto px-8 relative z-10">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-y-8 divide-x-0 md:divide-x divide-apricot/20 text-center">

        {[
          { icon: 'solar:chef-hat-linear',      title: 'Cuisine de marché',    sub: 'fraîcheur quotidienne',   script: true  },
          { icon: 'solar:user-circle-linear',   title: 'Chef Anthony Lusson',  sub: `14 ans d'expérience`,   script: false },
          { icon: 'solar:star-fall-linear',     title: 'Noté 4.8/5',           sub: 'sur 380 avis Google',    script: false },
          { icon: 'solar:clock-circle-linear',  title: 'Ouvert mar–sam',       sub: 'midi & soir',            script: false },
          { icon: 'solar:map-point-linear',     title: 'Prairie au Duc',       sub: 'Nantes centre',          script: false },
        ].map(({ icon, title, sub, script }, i) => (
          <div class={`flex flex-col items-center justify-center px-4${i === 4 ? ' col-span-2 md:col-span-1' : ''}`}>
            <iconify-icon icon={icon} width="24" class="text-apricot mb-3" stroke-width="1.5"></iconify-icon>
            <span class="text-white text-xs uppercase tracking-widest mb-1 font-sans">{title}</span>
            {script
              ? <span class="text-sky text-sm font-script">{sub}</span>
              : <span class="text-sky text-sm font-light">{sub}</span>
            }
          </div>
        ))}

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════
       3. CONCEPT
  ══════════════════════════════════════════ -->
  <section class="py-32 bg-white">
    <div class="max-w-[80rem] mx-auto px-8 grid grid-cols-1 md:grid-cols-2 gap-20 items-center">

      <!-- Photo chef -->
      <div class="w-full relative">
        <img
          src="/images/chef-plat.webp"
          alt="Mains du chef Anthony Lusson dressant un plat"
          class="w-full aspect-square object-cover rounded shadow-[0_20px_60px_rgba(221,156,122,0.3)] -rotate-1 transition-transform duration-700 hover:rotate-0"
          loading="lazy"
        />
      </div>

      <!-- Texte -->
      <div class="flex flex-col items-start md:pl-14">

        <span class="label-tag mb-4">Notre Philosophie</span>

        <h2 class="text-cobalt text-[3rem] md:text-[4rem] leading-[1.1] tracking-tight mb-8 font-script">
          Précision, passion et produits d'exception
        </h2>

        <p class="text-cobalt/70 text-base leading-relaxed mb-10 font-light">
          Anthony Lusson compose une carte courte qui change au fil des marchés.
          Pas de congélateur. Des producteurs choisis. Une cuisine qui dit la vérité.
        </p>

        <div class="flex flex-col gap-6 w-full">
          {[
            { icon: 'solar:leaf-linear',               title: 'Produits du marché',    desc: 'Sélectionnés 3 fois par semaine' },
            { icon: 'solar:document-text-linear',       title: 'Carte courte & précise', desc: '8 entrées, 6 plats, 5 desserts'  },
            { icon: 'solar:wineglass-triangle-linear',  title: 'Cave raisonnée',         desc: 'Vins nature et biodynamiques'    },
          ].map(({ icon, title, desc }) => (
            <div class="flex items-start gap-4 border-l-[3px] border-apricot pl-5 py-1">
              <iconify-icon icon={icon} width="20" class="text-apricot mt-1 shrink-0" stroke-width="1.5"></iconify-icon>
              <div>
                <h3 class="text-cobalt text-sm uppercase tracking-wide font-semibold mb-1 font-sans">{title}</h3>
                <p class="text-cobalt/60 text-sm font-light">{desc}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════
       4. MENUS
  ══════════════════════════════════════════ -->
  <section class="py-32 bg-cobalt noise-overlay relative">
    <div class="max-w-[80rem] mx-auto px-8 relative z-10">

      <!-- En-tête -->
      <div class="text-center flex flex-col items-center mb-16">
        <span class="label-tag mb-4">Nos Formules</span>
        <h2 class="text-white text-[3.5rem] md:text-[4.5rem] leading-[1.1] tracking-tight mb-4 font-script">
          Des saveurs qui racontent une saison
        </h2>
        <p class="text-white/60 text-sm md:text-base font-light font-sans">
          Carte renouvelée selon les arrivages du marché
        </p>
      </div>

      <!-- Cartes menus -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">

        {[
          {
            tag:   'Formule Déjeuner',
            name:  'Menu Marché',
            price: '25 €',
            desc:  'Entrée + plat ou plat + dessert',
            items: ['Œuf parfait, crème de champignons', 'Pêche du jour, beurre blanc', 'Ganache montée chocolat'],
            note:  'Midi uniquement · Mar–Ven',
          },
          {
            tag:   'Menu Signature',
            name:  'Menu Découverte',
            price: '45 €',
            desc:  'Entrée, plat, dessert au choix',
            items: ['Asperges rôties, jus de viande', 'Filet de canette, carottes fanes', 'Tartelette agrumes, thym'],
            note:  'Midi & Soir · Mar–Sam',
          },
          {
            tag:   'Menu Dégustation',
            name:  'Gastronomique',
            price: '68 €',
            desc:  `Menu en 5 temps, à l'aveugle`,
            items: ['Amuse-bouches du moment', '2 entrées / 1 plat / 1 pré-dessert', 'Dessert signature & mignardises'],
            note:  'Accord mets & vins : + 35 €',
          },
        ].map(({ tag, name, price, desc, items, note }) => (
          <div class="bg-white rounded overflow-hidden flex flex-col group shadow-[0_8px_40px_rgba(31,52,100,0.08)] transition-transform duration-300 hover:-translate-y-2">
            <!-- Bandeau sky -->
            <div class="h-20 bg-sky noise-paprika"></div>
            <!-- Corps -->
            <div class="p-8 flex flex-col flex-grow items-center text-center">
              <span class="text-cobalt text-[11px] uppercase tracking-widest mb-3 font-semibold font-sans">{tag}</span>
              <h3 class="text-cobalt text-[2.75rem] leading-none mb-4 font-script">{name}</h3>
              <div class="text-apricot text-3xl font-semibold mb-2 font-sans">{price}</div>
              <p class="text-cobalt/60 text-sm font-light mb-6">{desc}</p>
              <div class="w-12 h-px bg-cobalt/10 mb-6"></div>
              <div class="flex flex-col gap-2 mb-8">
                {items.map(item => (
                  <span class="text-cobalt/80 text-[15px] italic font-light">{item}</span>
                ))}
              </div>
              <div class="mt-auto pt-4 text-cobalt/50 text-xs font-sans">{note}</div>
            </div>
            <!-- CTA -->
            <a
              href="/la-carte"
              class="w-full bg-surface text-apricot text-center py-4 text-sm font-semibold font-sans transition-colors duration-300 group-hover:bg-apricot group-hover:text-white"
            >
              Voir le menu →
            </a>
          </div>
        ))}

      </div>

      <!-- CTA carte complète -->
      <div class="flex justify-center">
        <a href="/la-carte" class="btn-outline-white">
          Consulter la carte complète
        </a>
      </div>

    </div>
  </section>


  <!-- ══════════════════════════════════════════
       5. ÉVÉNEMENTS
  ══════════════════════════════════════════ -->
  <section class="bg-white flex flex-col md:flex-row">

    <!-- Photo salle privatisée -->
    <div class="w-full md:w-1/2 h-96 md:h-auto relative">
      <img
        src="/images/evenements-salle.webp"
        alt="Salle privatisée pour événements au restaurant Quélys"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
    </div>

    <!-- Contenu -->
    <div class="w-full md:w-1/2 p-10 md:p-20 relative" style="background-color:#1F3464">
      <div class="relative z-10 max-w-lg">

        <span class="label-tag mb-4 block">Groupes & Événements</span>

        <h2 class="text-white text-[3rem] md:text-[4rem] leading-[1.1] tracking-tight mb-6 font-script">
          Votre événement, notre scène
        </h2>

        <p class="text-white/70 text-base leading-relaxed mb-10 font-light">
          Salle privatisable jusqu'à 60 couverts. Idéal pour déjeuners d'affaires,
          séminaires, anniversaires et dîners de groupe.
        </p>

        <div class="flex flex-col gap-4 mb-12">
          {[
            { icon: 'solar:plate-linear',     label: `Déjeuners d'affaires`      },
            { icon: 'solar:wineglass-linear',  label: 'Dîners privatifs'           },
            { icon: 'solar:case-linear',       label: 'Séminaires & teambuilding'  },
            { icon: 'solar:confetti-linear',   label: 'Anniversaires & célébrations'},
          ].map(({ icon, label }) => (
            <div class="flex items-center gap-4">
              <iconify-icon icon={icon} width="24" class="text-apricot" stroke-width="1.5"></iconify-icon>
              <span class="text-white text-base font-sans">{label}</span>
            </div>
          ))}
        </div>

        <div class="flex flex-wrap gap-4">
          <a href="/contact#evenements" class="btn-primary">Demander un devis</a>
          <a href="/evenements" class="btn-ghost">Voir la salle</a>
        </div>

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════
       7. GALERIE INSTAGRAM
  ══════════════════════════════════════════ -->
  <section class="py-32 bg-white">
    <div class="max-w-[90rem] mx-auto px-8">

      <div class="text-center flex flex-col items-center mb-12">
        <span class="text-cobalt text-xs uppercase tracking-[4px] mb-4 font-semibold font-sans">
          Suivez Notre Cuisine
        </span>
        <h2 class="text-cobalt text-[3rem] md:text-[3.5rem] leading-[1.1] tracking-tight mb-4 font-script">
          L'atelier Quélys au quotidien
        </h2>
        <p class="text-cobalt/60 text-sm font-light font-sans">
          @quelys.nantes — Rejoignez la communauté
        </p>
      </div>

      <!-- Grille 3×2 -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-0 max-w-[60rem] mx-auto">
        {[
          { src: '/images/insta-1-img.webp', caption: 'Nouveau plat à la carte'  },
          { src: '/images/insta-2-img.webp', caption: 'Coulisses du service'     },
          { src: '/images/insta-3-img.webp', caption: 'Ambiance du soir'         },
          { src: '/images/insta-4-img.webp', caption: 'Notre sélection nature'   },
          { src: '/images/insta-5-img.webp', caption: 'Retour de marché'         },
          { src: '/images/insta-6-img.webp', caption: 'Précision'                },
        ].map(({ src, caption }) => (
          <div class="aspect-square relative group overflow-hidden bg-sky/20">
            <img
              src={src}
              alt={caption}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-cobalt/80 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-4 text-center">
              <iconify-icon icon="solar:camera-linear" width="32" class="text-apricot mb-3" stroke-width="1.5"></iconify-icon>
              <span class="text-white text-sm font-sans">{caption}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="flex justify-center mt-12">
        <a
          href="https://instagram.com/quelys.nantes"
          target="_blank"
          rel="noopener"
          class="btn-outline"
        >
          Suivre sur Instagram
        </a>
      </div>

    </div>
  </section>

  <!-- Neutralisation des liens internes (présentation page d'accueil seule) -->
  <script is:inline>
    document.querySelectorAll('a[href]').forEach((a) => {
      const href = a.getAttribute('href') || '';
      const isInternal =
        href.startsWith('/') &&
        !href.startsWith('//') &&
        !href.startsWith('/#');
      if (isInternal) a.setAttribute('href', '#');
    });
  </script>

</Base>
